generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  name            String
  username        String           @unique
  password        String?          @default("")
  confirm_code    String?
  avatar          String?
  roleUser        roleUser         @default(user)
  github_token    String?
  github_username String?
  github_id       String?
  provider        Provider?        @default(local)
  is_active       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspaces      User_workspace[]
  projects        project[]
  notifications   notification[]
  payments        payment[]
}

model User_workspace {
  id        String             @id @default(uuid())
  userId    String
  projectId String?
  role      roleWorkspace?     @default(member)
  status    statusSolicitation @default(pending)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  User      User               @relation(fields: [userId], references: [id])
  Project   project?           @relation(fields: [projectId], references: [id])
}

model Workspace {
  id           String   @id @default(uuid())
  name         String
  max_projects Int      @default(10)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model project {
  id                   String           @id @default(uuid())
  subdomain            String           @unique
  domain               String           @unique
  name                 String
  branch               String           @default("main")
  repo_url             String           @default("")
  amount_to_pay        Float?           @default(0)
  description          String?
  repo_saved           Boolean          @default(false)
  status_payment       PaymentStatus    @default(waiting)
  date_last_payment    DateTime?
  date_expire          DateTime?
  days                 Int?             @default(0)
  port                 String           @default("3000")
  build_cmd            String?
  clone                cloneStatus      @default(cloning)
  run_status           Boolean          @default(false)
  start_cmd            String?
  technology           technology?      @default(docker)
  default_plan         String?
  default_type_payment typePayment      @default(monthly)
  userId               String
  environments         String[]         @default([])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  payments             payment[]
  deploy               deploy[]
  user_workspace       User_workspace[]
  User                 User             @relation(fields: [userId], references: [id])
}

model deploy {
  id        String    @id @default(uuid())
  projectId String
  status    runStatus @default(building)
  success   Boolean   @default(true)
  logs      String[]  @default([])

  // dados do commit
  commit_id         String?
  commit_msg        String?
  commit_author     String?
  commit_email      String?
  commit_date       DateTime?
  commit_branch     String?
  commit_avatar_url String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Project   project  @relation(fields: [projectId], references: [id])
}

model payment {
  id            String         @id @default(uuid())
  userId        String
  projectId     String
  planId        String
  plan_name     String         @default("")
  ref           String?
  entity        String?        @default("")
  merchant      String         @default("")
  method        methodMerchant @default(ref)
  date_start    DateTime?
  date_end      DateTime?
  proof_payment String? // URL ou caminho do comprovante de pagamento
  time_in_day   Int?           @default(0)
  type_payment  typePayment
  amount        Float
  status        PaymentStatus  @default(pending)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  project       project        @relation(fields: [projectId], references: [id])
  User          User           @relation(fields: [userId], references: [id])
  Plan          plan           @relation(fields: [planId], references: [id], onDelete: SetDefault)
}

model plan {
  id           String  @id @default(uuid())
  name         String  @unique
  description  String?
  price        Float
  duration     Int // duration in days
  max_projects Int     @default(1)

  duration_description String?  @default("")
  features             String[] @default([])
  shortcut             String?  @default("")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  payment[]
}

model notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id])
}

enum Provider {
  local
  github
  google
}

enum PaymentStatus {
  waiting
  pending
  approved
  rejected
  failed
}

enum statusSolicitation {
  pending
  approved
  rejected
}

enum roleWorkspace {
  master
  member
}

enum typePayment {
  monthly
  yearly
}

enum methodMerchant {
  ref
  gpo
  proof
}

enum roleUser {
  admin
  user
}

enum technology {
  nodejs
  docker
}

enum cloneStatus {
  cloning
  cloned
  failed
}

enum runStatus {
  building
  stopped
  running
  failed
  unknown
}
